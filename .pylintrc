[MASTER]
# List of directories to search for source files. Comma-separated.
# This is where you can specify directories like `model` or `tests`
init-hook='import sys; sys.path.append("model")'

[MESSAGES CONTROL]
# Disable specific messages or categories
disable=C0111, C0103

[FORMAT]
# Maximum number of characters on a single line
max-line-length=100

[REPORTS]
# Output format for pylint (text or html)
output-format=text
